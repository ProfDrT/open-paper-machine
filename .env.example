# Google Gemini API key — required for PaperBanana AI figure generation
# Get yours at: https://aistudio.google.com/apikey
#
# The plugin checks these locations in order:
#   1. Shell environment variable GOOGLE_API_KEY (if already exported)
#   2. ~/.paperbanana.env  (global — recommended)
#   3. $PWD/.env           (project-local — legacy)
#
# Recommended: Copy this file to ~/.paperbanana.env and add your key there.
GOOGLE_API_KEY=your_api_key_here
